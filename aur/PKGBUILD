# Maintainer: Your Name <your.email@example.com>
pkgname=neo-mofox-launcher-git
_pkgname=neo-mofox-launcher
pkgver=r135.4af0150
pkgrel=1
pkgdesc="An elegant instance management launcher for Neo-MoFox QQ Bot. - 一个优雅的 Neo-MoFox QQ 机器人实例管理启动器"
arch=('x86_64') 
url="https://github.com/MoFox-Studio/Neo-MoFox-Launcher"
license=('AGPL3')
depends=('electron' 'nodejs' 'python' 'git')
makedepends=('npm' 'git')
provides=("$_pkgname")
conflicts=("$_pkgname")
optdepends=(
    'uv: Python 包管理器'
)
source=(
    "$_pkgname::git+$url.git"
)
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$_pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$srcdir/$_pkgname/Neo-MoFox-Launcher"
    
    # 安装 npm 依赖
    npm install --cache "${srcdir}/npm-cache"
}

build() {
    cd "$srcdir/$_pkgname/Neo-MoFox-Launcher"
    
    # 设置 Electron 版本
    export ELECTRON_SKIP_BINARY_DOWNLOAD=1
    
    # 不需要构建，因为我们使用系统的 electron
}

package() {
    cd "$srcdir/$_pkgname/Neo-MoFox-Launcher"
    
    # 安装应用文件
    install -dm755 "$pkgdir/usr/lib/$_pkgname"
    cp -r --no-preserve=ownership \
        src assets package.json \
        "$pkgdir/usr/lib/$_pkgname/"
    
    # 安装 node_modules（排除 electron）
    install -dm755 "$pkgdir/usr/lib/$_pkgname/node_modules"
    cp -r --no-preserve=ownership node_modules/* "$pkgdir/usr/lib/$_pkgname/node_modules/"
    rm -rf "$pkgdir/usr/lib/$_pkgname/node_modules/electron"
    
    # 创建启动脚本
    install -dm755 "$pkgdir/usr/bin"
    cat > "$pkgdir/usr/bin/$_pkgname" << EOF
#!/bin/sh
export ELECTRON_IS_DEV=0
# 设置 Electron 应用名称
export ELECTRON_FORCE_IS_PACKAGED=true
export APP_NAME="Neo-MoFox Launcher"
export ELECTRON_ICON="/usr/lib/$_pkgname/assets/images/icon.png"
exec electron /usr/lib/$_pkgname "\$@"
EOF
    chmod +x "$pkgdir/usr/bin/$_pkgname"
    
    # 安装桌面文件（从 aur 目录）
    install -Dm644 "$srcdir/$_pkgname/aur/$_pkgname.desktop" \
        "$pkgdir/usr/share/applications/$_pkgname.desktop"
    
    # 安装图标
    if [ -f "assets/images/icon.png" ]; then
        install -Dm644 "assets/images/icon.png" \
            "$pkgdir/usr/share/pixmaps/$_pkgname.png"
    fi
    
    # 安装许可证
    install -Dm644 "$srcdir/$_pkgname/LICENSE" \
        "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
    
    # 安装文档
    install -Dm644 "$srcdir/$_pkgname/README.md" \
        "$pkgdir/usr/share/doc/$_pkgname/README.md"
}
