{
  "name": "neo-mofox-launcher",
  "version": "1.0.0",
  "description": "Neo-MoFox Launcher - Material Design 3 Style",
  "main": "src/main.js",
  "scripts": {
    "start": "chcp 65001 >nul 2>&1 & electron .",
    "start:win": "chcp 65001 >nul 2>&1 & electron .",
    "start:linux": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:deb": "electron-forge make --targets @electron-forge/maker-deb",
    "dev": "chcp 65001 >nul 2>&1 & electron . --dev",
    "dev:win": "chcp 65001 >nul 2>&1 & electron . --dev",
    "dev:linux": "electron . --dev"
  },
  "author": "MoFox Studio",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "electron": "^33.0.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "systeminformation": "^5.31.1",
    "tree-kill": "^1.2.2"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Neo-MoFox Launcher",
        "executableName": "neo-mofox-launcher",
        "icon": "assets/icon",
        "asar": true,
        "ignore": [
          "^/dist($|/)",
          "^/\\.git($|/)",
          "^/\\.vscode($|/)",
          "^/\\.idea($|/)",
          "\\.md$",
          "^/logs($|/)",
          "\\.log$"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "neo_mofox_launcher",
            "setupIcon": "assets/icon.ico",
            "noMsi": true
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32",
            "linux",
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "options": {
              "maintainer": "MoFox Studio",
              "homepage": "https://github.com/MoFox-Studio/Neo-MoFox-Launcher",
              "icon": "assets/icon.png",
              "name": "neo-mofox-launcher",
              "productName": "Neo-MoFox Launcher",
              "genericName": "Bot Launcher",
              "description": "Neo-MoFox Launcher - MoFox QQ Bot 管理器",
              "section": "utils",
              "categories": [
                "Utility",
                "Network"
              ],
              "depends": [
                "libgtk-3-0",
                "libnotify4",
                "libnss3",
                "libxss1",
                "libxtst6",
                "xdg-utils",
                "libatspi2.0-0",
                "libuuid1",
                "libsecret-1-0"
              ]
            }
          }
        }
      ]
    }
  }
}
