{
  "name": "neo-mofox-launcher",
  "version": "1.0.0",
  "description": "Neo-MoFox Launcher - Material Design 3 Style",
  "main": "src/main.js",
  "scripts": {
    "start": "chcp 65001 >nul 2>&1 & electron .",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dev": "chcp 65001 >nul 2>&1 & electron . --dev"
  },
  "author": "MoFox Studio",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "electron": "^33.0.0"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "tree-kill": "^1.2.2"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Neo-MoFox Launcher",
        "icon": "assets/icon.ico",
        "asar": true,
        "ignore": [
          "^/dist($|/)",
          "^/\\.git($|/)",
          "^/\\.vscode($|/)",
          "^/\\.idea($|/)",
          "\\.md$",
          "^/logs($|/)",
          "\\.log$"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "neo_mofox_launcher",
            "setupIcon": "assets/icon.ico",
            "noMsi": true
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["win32"]
        }
      ]
    }
  }
}
