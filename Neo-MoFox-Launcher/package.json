{
  "name": "neo-mofox-launcher",
  "productName": "Neo-MoFox Launcher",
  "version": "1.0.0",
  "description": "Neo-MoFox Launcher - Material Design 3 Style",
  "main": "src/main.js",
  "bin": {
    "neo-mofox-cli": "src/cli/index.js"
  },
  "scripts": {
    "start": "chcp 65001 & electron .",
    "start:win": "chcp 65001 >nul 2>&1 & electron .",
    "start:linux": "electron .",
    "cli": "node src/cli/index.js",
    "dev": "chcp 65001 >nul 2>&1 & electron . --dev",
    "dev:win": "chcp 65001 >nul 2>&1 & electron . --dev",
    "dev:linux": "electron . --dev",
    "postinstall": "node scripts/rebuild-node-pty.js",
    "rebuild": "node scripts/rebuild-node-pty.js --force",
    "rebuild:x64": "node scripts/rebuild-node-pty.js --force --arch=x64",
    "rebuild:ia32": "node scripts/rebuild-node-pty.js --force --arch=ia32",
    "rebuild:arm64": "node scripts/rebuild-node-pty.js --force --arch=arm64",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:win:ia32": "electron-builder --win --ia32",
    "build:win:arm64": "electron-builder --win --arm64",
    "build:win:all": "electron-builder --win --x64 --ia32 --arm64",
    "build:linux": "electron-builder --linux --x64",
    "build:linux:ia32": "electron-builder --linux --ia32",
    "build:linux:arm64": "electron-builder --linux --arm64",
    "build:linux:all": "electron-builder --linux --x64 --ia32 --arm64",
    "build:dir": "electron-builder --dir"
  },
  "author": "MoFox Studio",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/MoFox-Studio/Neo-MoFox-Launcher",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@iarna/toml": "^2.2.5",
    "@lezer/highlight": "^1.2.3",
    "@material/material-color-utilities": "^0.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "extract-zip": "^2.0.1",
    "material-symbols": "^0.44.2",
    "node-pty": "^1.1.0",
    "strip-ansi": "^7.2.0",
    "systeminformation": "^5.31.1",
    "tree-kill": "^1.2.2"
  }
}
